{
  "config": {
    "step": {
      "user": {
        "title": "Add your Xiaomi vacuum",
        "description": "Sign in by email for the live map.",
        "menu_options": {
          "credentials": "Email & password (gets the live map)",
          "local": "Device IP & token (control only, no map)"
        }
      },
      "credentials": {
        "title": "Sign in to Mi Home",
        "description": "Sign in once. It stays logged in after that.",
        "data": {
          "username": "Email, phone number or Mi account ID",
          "password": "Password"
        }
      },
      "local": {
        "title": "Local connection",
        "description": "IP address and 32-character token. Control and sensors, no map.",
        "data": {
          "host": "IP address",
          "token": "Token"
        }
      },
      "captcha": {
        "title": "Quick human check",
        "description": "Xiaomi wants to know you're real. Type the characters below:\n\n![captcha]({captcha_url})",
        "data": {
          "code": "Characters from the image"
        }
      },
      "twofa": {
        "title": "Enter the code",
        "description": "Xiaomi just emailed you a code. Put it in below.",
        "data": {
          "code": "Verification code"
        }
      },
      "devices": {
        "title": "Choose your vacuum",
        "description": "There's more than one vacuum on this account. Pick the one to add.",
        "data": {
          "device": "Vacuum"
        }
      },
      "reauth_confirm": {
        "title": "Sign in to Xiaomi again",
        "description": "Your session ran out and couldn't renew on its own. Sign in again to bring the live map back.",
        "data": {
          "username": "Email, phone number or Mi account ID",
          "password": "Password"
        }
      }
    },
    "error": {
      "unsupported_model": "This model isn't supported yet.",
      "cannot_connect": "Couldn't reach the vacuum at that IP with that token."
    },
    "abort": {
      "already_configured": "This vacuum is already set up.",
      "reauth_successful": "You're back in. The live map's restored.",
      "login_failed": "Xiaomi wouldn't accept that. Check your email and password, then try again.",
      "no_devices": "No supported vacuums on this account.",
      "unsupported_model": "This model isn't supported yet (ijai / Xiaomi-branded ijai vacuums only)."
    }
  },
